PORT=3000
NODE_ENV=development

# Set to true to run with in-memory storage (no PostgreSQL needed)
DEMO_MODE=false

# Must be >= 32 characters
HMAC_SECRET=change_me_to_something_32_chars_long!!

# JWT signing secret
JWT_SECRET=another_strong_secret_for_jwt_signing

# PostgreSQL connection
DATABASE_URL=postgresql://postgres:YOUR_PASSWORD@localhost:5432/nfc_payments

# Redis (optional)
# REDIS_URL=redis://localhost:6379

# Token TTL in hours
TOKEN_TTL_HOURS=24
